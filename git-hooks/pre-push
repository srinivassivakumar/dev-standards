#!/usr/bin/env bash
set -euo pipefail

echo ""
echo "=== Santosh Checks =================================="

remote="$1"
url="$2"

if [ -t 1 ]; then
  bun ~/.config/opencode/scripts/update-santosh-rules.ts 2>/dev/null
else
  bun ~/.config/opencode/scripts/update-santosh-rules.ts 2>/dev/null
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  bun ~/.config/opencode/scripts/scan-santosh-violations.ts "$local_sha" "$remote_sha" 2>&1 || {
    exit $?
  }
done

bun ~/.config/opencode/scripts/check-santosh-feedback.ts 2>/dev/null || {
  exit_code=$?
  if [ -f ~/.config/opencode/.santosh_feedback_pending ]; then
    echo ""
    echo "Run 'sync-santosh-rules' to update the standards file, then push again."
  fi
  exit $exit_code
}

echo "=== Santosh Checks: all clear ======================"
echo ""
