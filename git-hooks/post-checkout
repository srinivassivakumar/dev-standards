#!/usr/bin/env bash
set -euo pipefail

previous="$1"
new="$2"
branch_change="$3"

if [ "$new" = "$previous" ]; then
  exit 0
fi

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
claude_file="$repo_root/CLAUDE.md"

if [ ! -f "$claude_file" ]; then
  exit 0
fi

reference_line="Before writing tests, fixtures, seeds, or DB code — read and follow ~/.config/opencode/SANTOSH_STANDARDS.md"

if grep -q "SANTOSH_STANDARDS.md" "$claude_file" 2>/dev/null; then
  exit 0
fi

read -p "Add Santosh standards reference to CLAUDE.md? [Y/n] " -n 1 -r
echo
if [[ $REPLY =~ ^[Nn]$ ]]; then
  exit 0
fi

echo "" >> "$claude_file"
echo "$reference_line" >> "$claude_file"
echo "Added Santosh standards reference to $claude_file (unstaged)"
